# Optional demo storage overrides.
# If you leave these unset, the demo auto-generates its own bucket names from CDNGINE_DEMO_BUCKET_PREFIX.

CDNGINE_DEMO_BUCKET_PREFIX=cdngine-demo
CDNGINE_DEMO_API_BASE_URL=https://api.cdngine.local
CDNGINE_DEMO_URL=http://localhost:5173
CDNGINE_DEMO_INGEST_BUCKET=
CDNGINE_DEMO_SOURCE_BUCKET=
CDNGINE_DEMO_DERIVED_BUCKET=
CDNGINE_DEMO_EXPORTS_BUCKET=
