{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.cdngine.dev/examples/public/presentation-asset-manifest.schema.json",
  "title": "PresentationAssetManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestType",
    "assetId",
    "versionId",
    "serviceNamespaceId",
    "generatedAt",
    "normalizedDocument",
    "slides"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "manifestType": {
      "type": "string",
      "const": "presentation-default"
    },
    "assetId": {
      "type": "string"
    },
    "versionId": {
      "type": "string"
    },
    "serviceNamespaceId": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "normalizedDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "byteLength",
        "checksum",
        "contentType",
        "deterministicKey",
        "recipeId",
        "schemaVersion",
        "variantKey"
      ],
      "properties": {
        "byteLength": {
          "type": "integer",
          "minimum": 0
        },
        "checksum": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        },
        "deterministicKey": {
          "type": "string"
        },
        "recipeId": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string"
        },
        "variantKey": {
          "type": "string",
          "const": "normalized-pdf"
        }
      }
    },
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "byteLength",
          "checksum",
          "contentType",
          "deterministicKey",
          "pageNumber",
          "recipeId",
          "schemaVersion",
          "variantKey"
        ],
        "properties": {
          "byteLength": {
            "type": "integer",
            "minimum": 0
          },
          "checksum": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "deterministicKey": {
            "type": "string"
          },
          "pageNumber": {
            "type": "integer",
            "minimum": 1
          },
          "recipeId": {
            "type": "string",
            "const": "slide-images"
          },
          "schemaVersion": {
            "type": "string"
          },
          "variantKey": {
            "type": "string"
          }
        }
      }
    }
  }
}
