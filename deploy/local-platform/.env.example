# Purpose: Documents the overridable environment values for the local fast-start stack.
# Governing docs:
# - deploy/local-platform/README.md
# - docs/environment-and-deployment.md
# External references:
# - https://docs.docker.com/compose/environment-variables/
# Tests:
# - docker compose --env-file deploy/local-platform/.env.example -f deploy/local-platform/compose.fast-start.yaml config

POSTGRES_PORT=5432
REDIS_PORT=6379
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
TUSD_PORT=1080
KOPIA_PORT=51515
OCI_REGISTRY_PORT=5000

AWS_REGION=us-east-1
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
STAGING_BUCKET=cdngine-staging
DERIVED_BUCKET=cdngine-derived
KOPIA_BUCKET=cdngine-kopia
KOPIA_REPOSITORY_PASSWORD=cdngine-local-repository
TUSD_OBJECT_PREFIX=uploads/

CDNGINE_DATABASE_URL=postgresql://cdngine:cdngine@localhost:5432/cdngine
TEMPORAL_ADDRESS=localhost:7233
RUSTFS_ENDPOINT=http://localhost:9000
TUSD_ENDPOINT=http://localhost:1080/files/
KOPIA_SERVER_URL=http://localhost:51515
OCI_REGISTRY_URL=http://localhost:5000
