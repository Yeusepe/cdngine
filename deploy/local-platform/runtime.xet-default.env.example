# Purpose: Documents the app and worker runtime environment for using the local fast-start stack with Xet as the default canonical-source engine.
# Governing docs:
# - deploy/local-platform/README.md
# - deploy/production/README.md
# - docs/environment-and-deployment.md
# - docs/source-plane-strategy.md
# External references:
# - https://docs.docker.com/compose/environment-variables/
# - https://huggingface.co/docs/xet/en/deduplication
# - https://github.com/huggingface/xet-core
# Tests:
# - packages/storage/test/runtime-storage-config.test.mjs
# - packages/observability/test/readiness-profile.test.mjs

CDNGINE_DEPLOYMENT_PROFILE=local-fast-start
CDNGINE_STORAGE_LAYOUT_MODE=multi-bucket
CDNGINE_INGEST_BUCKET=cdngine-staging
# The local fast-start stack does not provision a separate Xet service, but it does reserve a
# dedicated source bucket for Xet-default app and worker runtime examples.
CDNGINE_SOURCE_BUCKET=cdngine-source
CDNGINE_DERIVED_BUCKET=cdngine-derived
CDNGINE_EXPORTS_BUCKET=cdngine-exports
CDNGINE_INGEST_PREFIX=uploads
CDNGINE_SOURCE_PREFIX=source
CDNGINE_DERIVED_PREFIX=derived
CDNGINE_EXPORTS_PREFIX=exports

CDNGINE_TIERING_SUBSTRATE=rustfs
CDNGINE_SOURCE_DELIVERY_MODE=proxy
CDNGINE_HOT_READ_LAYER=none
# Xet is the default source engine when CDNGINE_SOURCE_ENGINE is unset.
CDNGINE_XET_COMMAND=xet
CDNGINE_XET_COMMAND_ARGS_JSON=[]
CDNGINE_XET_TIMEOUT_MS=30000
# CDNGINE_XET_WORKSPACE_PATH=C:\cdngine\xet
# CDNGINE_XET_WORKING_DIRECTORY=C:\Users\you\cdngine
# CDNGINE_XET_SERVICE_ENDPOINT=http://127.0.0.1:9002
# CDNGINE_XET_AUTH_TOKEN=replace-me
# Keep the Kopia lane wired only for legacy rows and emergency fallback during migration.
# CDNGINE_KOPIA_EXECUTABLE=kopia
# CDNGINE_KOPIA_WORKING_DIRECTORY=C:\Users\you\cdngine
# CDNGINE_KOPIA_TIMEOUT_MS=30000

# This matches the current local-fast-start readiness default. Override only if a narrower
# app-specific readiness gate is intentional.
CDNGINE_READINESS_REQUIRED=postgres,redis,temporal,tusd,source-repository,oci-registry
