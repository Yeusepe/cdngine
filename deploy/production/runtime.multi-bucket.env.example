# Purpose: Documents a multi-bucket deployment profile where each logical storage role maps to its own bucket.
# Governing docs:
# - deploy/production/README.md
# - docs/environment-and-deployment.md
# - docs/storage-tiering-and-materialization.md
# External references:
# - https://docs.docker.com/compose/environment-variables/
# Tests:
# - packages/storage/test/runtime-storage-config.test.ts

CDNGINE_DEPLOYMENT_PROFILE=production-default
CDNGINE_STORAGE_LAYOUT_MODE=multi-bucket
CDNGINE_INGEST_BUCKET=cdngine-ingest
CDNGINE_SOURCE_BUCKET=cdngine-source
CDNGINE_DERIVED_BUCKET=cdngine-derived
CDNGINE_EXPORTS_BUCKET=cdngine-exports
CDNGINE_INGEST_PREFIX=ingest
CDNGINE_SOURCE_PREFIX=source
CDNGINE_DERIVED_PREFIX=derived
CDNGINE_EXPORTS_PREFIX=exports

CDNGINE_TIERING_SUBSTRATE=seaweedfs
CDNGINE_SOURCE_DELIVERY_MODE=proxy
CDNGINE_HOT_READ_LAYER=alluxio
# Xet is the default source engine when CDNGINE_SOURCE_ENGINE is unset.
# Set CDNGINE_SOURCE_ENGINE=kopia only for the temporary migration or emergency fallback lane.
CDNGINE_XET_COMMAND=xet
CDNGINE_XET_COMMAND_ARGS_JSON=[]
CDNGINE_XET_TIMEOUT_MS=30000
# CDNGINE_XET_WORKSPACE_PATH=/srv/cdngine/xet
# CDNGINE_XET_WORKING_DIRECTORY=/srv/cdngine
# CDNGINE_XET_SERVICE_ENDPOINT=https://xet.internal
# CDNGINE_XET_AUTH_TOKEN=replace-me
# CDNGINE_KOPIA_EXECUTABLE=kopia
# CDNGINE_KOPIA_WORKING_DIRECTORY=/srv/cdngine/kopia
# CDNGINE_KOPIA_TIMEOUT_MS=30000

CDNGINE_READINESS_REQUIRED=postgres,redis,temporal,tusd,source-repository,derived-store,exports-store
