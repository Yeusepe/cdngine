{
  "name": "cdngine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "node scripts/clean.mjs",
    "contracts:bundle": "node scripts/bundle-contracts.mjs",
    "contracts:examples": "node scripts/check-contract-examples.mjs",
    "contracts:lint": "redocly lint --config redocly.yaml",
    "contracts:check": "npm run contracts:lint && npm run contracts:bundle && npm run contracts:examples",
    "docs:check": "node scripts/check-workspace-metadata.mjs && node scripts/check-source-reference-headers.mjs",
    "sdk:generate": "npm run contracts:bundle && node scripts/generate-typescript-sdk.mjs",
    "sdk:check": "npm run contracts:bundle && node scripts/generate-typescript-sdk.mjs --check",
    "lint": "npm run docs:check && npm run contracts:check && npm run sdk:check && npm run lint --workspaces --if-present",
    "test": "npm run docs:check && npm run test --workspaces --if-present",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "verify": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@redocly/cli": "^2.28.0",
    "@types/node": "^24.6.0",
    "ajv": "^8.18.0",
    "openapi-typescript": "^7.10.1",
    "typescript": "^5.9.3"
  }
}
