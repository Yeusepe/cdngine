{
  "name": "@cdngine/registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run prisma:validate && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "test": "npm run prisma:validate && node --test"
  },
  "cdngine": {
    "governingDocs": [
      "docs/domain-model.md",
      "docs/persistence-model.md",
      "docs/state-machines.md",
      "docs/idempotency-and-dispatch.md"
    ],
    "programmingPractices": [
      "docs/regular-programming-practices/resilient-coding-debugging-and-performance.md",
      "docs/regular-programming-practices/interfaces-and-data-flow.md",
      "docs/regular-programming-practices/storage-and-state.md",
      "docs/regular-programming-practices/testing-and-scale.md",
      "docs/regular-programming-practices/security-verification-baseline.md",
      "docs/regular-programming-practices/implementation-strategy.md"
    ],
    "externalReferences": [
      "https://www.prisma.io/docs/orm/prisma-client/queries/transactions",
      "https://www.prisma.io/docs/orm/prisma-schema/data-model/models",
      "https://www.postgresql.org/docs/",
      "https://semver.org/"
    ]
  },
  "dependencies": {
    "@prisma/client": "^7.7.0"
  },
  "devDependencies": {
    "prisma": "^7.7.0"
  }
}
